                    "formatOptions": {
                      "palette": "blue"
                    }
                  },
                  {
                    "columnMatch": "targetResourceId",
                    "formatter": 5
                  }
                ],
                "rowLimit": 1000,
                "filter": true,
                "labelSettings": [
                  {
                    "columnId": "Ambiente",
