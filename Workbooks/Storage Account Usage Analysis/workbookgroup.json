            "query": "{\"version\":\"Merge/1.0\",\"merges\":[{\"id\":\"a1b2c3d4-0001-0001-0001-000000000001\",\"mergeType\":\"leftouter\",\"leftTable\":\"MetricsTransactionsGrid\",\"rightTable\":\"MetricsCapacityGrid\",\"leftColumn\":\"Name\",\"rightColumn\":\"Name\"}],\"projectRename\":[{\"originalName\":\"[MetricsTransactionsGrid].Subscription\",\"mergedName\":\"Subscription\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsTransactionsGrid].Name\",\"mergedName\":\"Name\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsTransactionsGrid].Transações\",\"mergedName\":\"Transações\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsTransactionsGrid].Transações Timeline\",\"mergedName\":\"Transações Timeline\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsTransactionsGrid].Ingress\",\"mergedName\":\"Ingress\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsTransactionsGrid].Ingress Timeline\",\"mergedName\":\"Ingress Timeline\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsTransactionsGrid].Egress\",\"mergedName\":\"Egress\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsTransactionsGrid].Egress Timeline\",\"mergedName\":\"Egress Timeline\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsCapacityGrid].Subscription\",\"mergedName\":\"Subscription1\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsCapacityGrid].Name\",\"mergedName\":\"Name1\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsCapacityGrid].Namespace\",\"mergedName\":\"Namespace\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[MetricsCapacityGrid].Metric\",\"mergedName\":\"Metric\",\"fromId\":\"a1b2c3d4-0001-0001-0001-000000000001\"},{\"originalName\":\"[